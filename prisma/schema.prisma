// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

generator json {
  provider = "prisma-json-types-generator"
}

generator zod {
  provider          = "zod-prisma-types"
  output            = "../src/generated/zod"
  useTypeAssertions = true
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator custom_generator {
  provider = "prisma-generator-fake-data"
  output   = "../src/generated/faker/data.ts"
}

// =============================================
// 0. AUTH & AUTHORIZATION (Phân quyền hệ thống)
// =============================================

model Role {
  id           String   @id @default(uuid())
  name         String   @unique
  description  String?
  isSystemRole Boolean  @default(false)
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  rolePermissions RolePermission[]
  employeeRoles   EmployeeRole[]
}

model Permission {
  id                 String   @id @default(uuid())
  name               String
  description        String?
  key                String   /// @zod.string.describe("Pattern: [/resource]_[action], e.g: [/product]_[read]")
  isSystemPermission Boolean  @default(false)
  
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  rolePermissions RolePermission[]

  @@unique([name, key])
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model EmployeeRole {
  employeeId String
  roleId     String
  createdAt  DateTime @default(now())

  employee Employee @relation(fields: [employeeId], references: [id])
  role     Role     @relation(fields: [roleId], references: [id])

  @@id([employeeId, roleId])
}

// =============================================
// 1. MASTER TABLES (Bảng danh mục)
// =============================================

model Position {
  id        String   @id @default(uuid()) // MaChucVu
  name      String   // TenChucVu
  salary    Decimal  // Luong

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  employees Employee[]
}

model DiningTable {
  id        String   @id @default(uuid()) // MaBan
  status    String   // TinhTrangBan

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  reservations Reservation[]
}

model Budget {
  id        String   @id @default(uuid()) // MaNganSach
  name      String   // TenNganSach
  balance   Decimal  // SoDu

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  invoices        Invoice[]
  importOrders    ImportOrder[]
  exportOrders    ExportOrder[]
  expenseVouchers ExpenseVoucher[]
}

model MenuItem {
  id        String   @id @default(uuid()) // MaThucDon
  name      String   // Ten
  price     Decimal  // GiaTien

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  invoiceDetails InvoiceDetail[]
  ingredients    MenuItemIngredient[]
}

model Promotion {
  id        String   @id @default(uuid()) // MaKhuyenMai
  name      String   // TenKhuyenMai

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  invoicePromotions InvoicePromotion[]
}

model Unit {
  id        String   @id @default(uuid()) // MaDonViTinh
  name      String   // TenDonVi

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  inventoryItems InventoryItem[]
}

model Equipment {
  id        String   @id @default(uuid()) // MaThietBi
  name      String   // TenThietBi

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  importEquipmentDetails ImportEquipmentDetail[]
}

// =============================================
// 2. ENTITY TABLES (Các bảng thực thể chứa khóa ngoại)
// =============================================

model Employee {
  id          String   @id @default(uuid()) // MaNhanVien
  email       String   @unique /// @zod.string.email()
  fullName    String   // HoTen
  address     String?  // DiaChi
  phoneNumber String?  // SoDienThoai
  username    String   @unique // TenDangNhap
  ///FAKE:faker.internet.password()
  password    String   // MatKhau
  isActive    Boolean  @default(true) // TrangThai

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  positionId  String   // MaChucVu
  position    Position @relation(fields: [positionId], references: [id])

  importOrders    ImportOrder[]
  exportOrders    ExportOrder[]
  reservations    Reservation[]
  expenseVouchers ExpenseVoucher[]
  invoices        Invoice[]       
  employeeRoles   EmployeeRole[]  
}

model InventoryItem {
  id        String   @id @default(uuid()) // MaHangHoa
  name      String   // TenHangHoa

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  unitId    String   // MaDonViTinh
  unit      Unit     @relation(fields: [unitId], references: [id])

  menuIngredients   MenuItemIngredient[]
  importItemDetails ImportItemDetail[]
  exportItemDetails ExportItemDetail[]
}

model Invoice {
  id          String   @id @default(uuid()) // MaHoaDon
  totalAmount Decimal  // TongTien

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  budgetId    String   // MaNganSach
  budget      Budget   @relation(fields: [budgetId], references: [id])

  employeeId  String? 
  employee    Employee? @relation(fields: [employeeId], references: [id])

  reservations      Reservation[]
  invoiceDetails    InvoiceDetail[]
  invoicePromotions InvoicePromotion[]
}

model ImportOrder {
  id         String   @id @default(uuid()) // MaDonNhap
  importDate DateTime // NgayNhap

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  employeeId String   // MaNhanVien
  employee   Employee @relation(fields: [employeeId], references: [id])

  budgetId   String   // MaNganSach
  budget     Budget   @relation(fields: [budgetId], references: [id])

  importItemDetails      ImportItemDetail[]
  importEquipmentDetails ImportEquipmentDetail[]
}

model ExportOrder {
  id         String   @id @default(uuid()) // MaDonXuat
  exportDate DateTime // NgayXuat

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  deletedAt  DateTime?

  employeeId String   // MaNhanVien
  employee   Employee @relation(fields: [employeeId], references: [id])

  budgetId   String   // MaNganSach
  budget     Budget   @relation(fields: [budgetId], references: [id])

  exportItemDetails ExportItemDetail[]
}

// =============================================
// 3. DETAIL / JUNCTION TABLES
// =============================================

model Reservation {
  id           Int      @id @default(autoincrement()) // MaCTDatBan
  customerName String?  // KhachHang
  dateTime     DateTime // NgayGio

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tableId      String   // MaBan
  table        DiningTable @relation(fields: [tableId], references: [id])

  employeeId   String   // MaNhanVien
  employee     Employee @relation(fields: [employeeId], references: [id])

  invoiceId    String?  // Optional (when first reservation is converted to invoice))
  invoice      Invoice? @relation(fields: [invoiceId], references: [id])
}

model InvoiceDetail {
  invoiceId  String   // MaHoaDon
  invoice    Invoice  @relation(fields: [invoiceId], references: [id])

  menuItemId String   // MaThucDon
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])

  quantity   Int      // SoLuong
  amount     Decimal  // SoTien
  
  createdAt  DateTime @default(now())

  @@id([invoiceId, menuItemId])
}

model InvoicePromotion {
  invoiceId   String   // MaHoaDon
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])

  promotionId String   // MaKhuyenMai
  promotion   Promotion @relation(fields: [promotionId], references: [id])

  createdAt   DateTime @default(now())

  @@id([invoiceId, promotionId])
}

model MenuItemIngredient {
  menuItemId      String   // MaThucDon
  menuItem        MenuItem @relation(fields: [menuItemId], references: [id])

  inventoryItemId String   // MaHangHoa
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  quantity        Decimal  // DinhLuong
  
  createdAt       DateTime @default(now())

  @@id([menuItemId, inventoryItemId])
}

model ImportItemDetail {
  importOrderId   String   // MaDonNhap
  importOrder     ImportOrder @relation(fields: [importOrderId], references: [id])

  inventoryItemId String   // MaHangHoa
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  quantity        Int      // SoLuong
  importPrice     Decimal  // GiaNhap

  createdAt       DateTime @default(now())

  @@id([importOrderId, inventoryItemId])
}

model ImportEquipmentDetail {
  importOrderId String   // MaDonNhap
  importOrder   ImportOrder @relation(fields: [importOrderId], references: [id])

  equipmentId   String   // MaThietBi
  equipment     Equipment @relation(fields: [equipmentId], references: [id])

  quantity      Int      // SoLuong
  importPrice   Decimal  // GiaNhap
  
  createdAt     DateTime @default(now())

  @@id([importOrderId, equipmentId])
}

model ExportItemDetail {
  exportOrderId   String   // MaDonXuat
  exportOrder     ExportOrder @relation(fields: [exportOrderId], references: [id])

  inventoryItemId String   // MaHangHoa
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])

  quantity        Int      // SoLuong

  createdAt       DateTime @default(now())

  @@id([exportOrderId, inventoryItemId])
}

// =============================================
// 4. OTHER TABLES
// =============================================

model SystemSetting {
  id          String   @id @default(uuid()) // MaCaiDat
  value       String   // GiaTri
  description String?  // MoTa
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExpenseVoucher {
  id          String   @id @default(uuid()) // MaPhieuChi
  expenseDate DateTime // NgayChi
  description String   // KhoanChi
  amount      Decimal  // SoTien

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  budgetId    String   // MaNganSach
  budget      Budget   @relation(fields: [budgetId], references: [id])

  employeeId  String   // MaNhanVien
  employee    Employee @relation(fields: [employeeId], references: [id])
}